# FullNoise AI — API environment (copy to .env)
# Database (Postgres). For local: postgresql+asyncpg://user:pass@localhost:5432/fullnoise
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fullnoise

# OpenAI (report generation + Q&A)
OPENAI_API_KEY=sk-your-openai-key

# Resend (send reports + magic links; inbound webhook URL in Resend dashboard)
# IMPORTANT: Use an API key from the SAME Resend account where your domain is verified.
# If you have multiple Resend accounts, create the key in the account that has the domain
# (and configure the inbound webhook there too), or sends/replies won't match that account.
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=reports@yourdomain.com

# Redis (for background job queue)
REDIS_URL=redis://localhost:6379/0

# Auth: same secret as Next.js NEXTAUTH_SECRET so API can verify JWTs
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Optional: base URL of the frontend (for magic link and CORS)
FRONTEND_URL=http://localhost:3000
